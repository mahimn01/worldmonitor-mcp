# World Monitor MCP - Configuration
# Copy to .env and fill in your keys

# Base URL of the World Monitor API (default: https://worldmonitor.app)
WORLDMONITOR_BASE_URL=https://worldmonitor.app

# Optional: API key for authenticated access (if required by your instance)
WORLDMONITOR_API_KEY=

# Optional: Request timeout in milliseconds (default: 30000)
WORLDMONITOR_TIMEOUT=30000

# === Persistence & caching (optional) ===
# NOTE: these keys ship commented out — `cp .env.example .env` must not set
# empty values. (Empty strings are also treated as unset by the loader.)

# Directory for the SQLite cache/state DB (default: ~/.cache/worldmonitor).
# SQLite persistence needs Node >= 22.5; otherwise the server transparently
# falls back to an in-memory store (cache + change-history won't persist).
# WORLDMONITOR_DATA_DIR=/path/to/data

# TTL in seconds for the cached brief://today resource (default: 900).
# Per-feed composite caching uses fixed TTLs (30s-1h) tuned per data source.
# WORLDMONITOR_CACHE_TTL=900

# Comma-separated watchlist symbols, surfaced via the watchlist:// resource and
# used as the scan_convergence fallback universe (overrides <data dir>/watchlist.json).
# WORLDMONITOR_WATCHLIST=SPY,QQQ,NVDA,^VIX

# SEC requires an EMAIL-shaped User-Agent (URL-style UAs get 403'd). Override the
# default contact used for EDGAR requests (company_tickers, Form 4, submissions).
# SEC_USER_AGENT=your-app/1.0 (you@example.com)

# === Direct Handler API Keys (all free tier) ===

# Finnhub — congressional trades, economic/earnings/IPO calendar, social sentiment
# Get free key: https://finnhub.io/register
FINNHUB_API_KEY=

# FRED (Federal Reserve Economic Data) — economic calendar fallback
# Get free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# USDA NASS QuickStats — crop production reports
# Get free key: https://quickstats.nass.usda.gov/api
USDA_API_KEY=

# OpenSanctions — sanctions/watchlist search (optional)
# Get free key: https://opensanctions.org
OPENSANCTIONS_API_KEY=
